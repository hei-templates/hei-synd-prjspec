
@article{gallus_does_2003,
	title = {Does pizza protect against cancer?},
	volume = {107},
	issn = {0020-7136},
	doi = {10.1002/ijc.11382},
	abstract = {We analyzed the potential role of pizza on cancer risk, using data from an integrated network of case-control studies conducted in Italy between 1991 and 2000. Cancer sites were: oral cavity and pharynx (598 cases), esophagus (304 cases), larynx (460 cases), colon (1,225 cases) and rectum (728 cases). Controls were 4,999 patients admitted for acute, non-neoplastic conditions to the same hospital network as cases. Odds ratios for regular pizza consumers were 0.66 (95\% confidence interval, CI = 0.47-0.93) for oral and pharyngeal cancer, 0.41 (95\% CI = 0.25-0.69) for oesophageal, 0.82 (95\% CI = 0.56-1.19) for laryngeal, 0.74 (95\% CI = 0.61-0.89) for colon and 0.93 (95\% CI = 0.75-1.17) for rectal cancer. Pizza appears therefore to be a favorable indicator of risk for digestive tract neoplasms in this population.},
	language = {eng},
	number = {2},
	journal = {International Journal of Cancer},
	author = {Gallus, Silvano and Bosetti, Cristina and Negri, Eva and Talamini, Renato and Montella, Maurizio and Conti, Ettore and Franceschi, Silvia and La Vecchia, Carlo},
	month = nov,
	year = {2003},
	keywords = {Case-Control Studies, Diet, Digestive System Neoplasms, Female, Food, Humans, Italy, Male, Odds Ratio, Risk Factors},
	pages = {283--284},
	file = {Full Text:/Users/zas/Zotero/storage/2UC49BKF/Gallus et al. - 2003 - Does pizza protect against cancer.pdf:application/pdf},
}

